# Supabase配置
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# ===== 主要识别引擎（当前使用 Groq Llama 4 Scout Vision）=====
OPENAI_API_KEY=sa
OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ===== 备用模型配置 =====
# 切换引擎只需修改上面三行，例如使用通义千问（仅从中国大陆服务器访问）:
#   OPENAI_API_KEY=sk-5354ea96c69b44ed96705e8e446f84f9
#   OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
#   OPENAI_MODEL=qwen-vl-max-latest
#
# 或使用 Mistral Pixtral:
#   OPENAI_API_KEY=nQcLxVxItpYsBJmC3tkHWNhbDNE6Jgx4
#   OPENAI_API_BASE=https://api.mistral.ai/v1
#   OPENAI_MODEL=pixtral-large-latest
DASHSCOPE_API_KEY=sk-a
# DeepSeek
DEEPSEEK_API_KEY=sk-a

# 智谱 GLM
GLM_API_KEY=a.a

# 月之暗面 Moonshot
MOONSHOT_API_KEY=sk-a

# 通义千问
TONGYI_API_KEY=sk-a

# 腾讯混元
TENGCENT_API_KEY=a

# 讯飞星火
SPARK_API_KEY=aK

# 字节豆包
DOUBAO_API_KEY=a

# Anthropic Claude
ANTHROPIC_API_KEY=sk-a
# Google Gemini
GEMINI_API_KEY=a

# DeepAI
DEEPAI_API_KEY=a

# xAI Grok
XAI_API_KEY=xai-a

# Mistral
MISTRAL_API_KEY=a

# Groq
GROQ_API_KEY=a

# 其他配置
NODE_ENV=development
